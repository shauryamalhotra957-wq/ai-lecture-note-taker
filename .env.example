# Required for real OpenAI transcription and AI enrichment.
# Without this, both apps run in deterministic demo mode.
OPENAI_API_KEY=

# Whisper-compatible default requested by the prototype brief.
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Current OpenAI model guidance favors GPT-5.6 for new text workflows.
OPENAI_TEXT_MODEL=gpt-5.6

# Optional runtime storage directory. Defaults to ./var.
AI_MEDIA_DATA_DIR=

# Set to 1 to prevent external API calls even if OPENAI_API_KEY is present.
AI_MEDIA_FORCE_DEMO=0

